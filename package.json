{
  "name": "caveman-pi-extension",
  "version": "0.3.0",
  "description": "Caveman mode for pi: ultra-compressed responses, terse commits, terse reviews, and memory compression.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "caveman",
    "skills",
    "productivity"
  ],
  "files": [
    "extensions/",
    "skills/caveman-commit/",
    "skills/caveman-review/",
    "caveman-compress/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/viartemev/caveman-pi-extension#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viartemev/caveman-pi-extension.git"
  },
  "scripts": {
    "sync:upstream": "bash scripts/sync-upstream.sh",
    "update:upstream": "git submodule update --remote --merge vendor/caveman && bash scripts/sync-upstream.sh"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/caveman.ts"
    ],
    "skills": [
      "./skills/caveman-commit",
      "./skills/caveman-review",
      "./caveman-compress"
    ]
  }
}
